{
  "settings": {
    "analysis": {
      "tokenizer": {
        "single_char_ngram_tokenizer": {
          "type": "ngram",
          "min_gram": 1,
          "max_gram": 2
        }
      },
      "analyzer": {
        "single_char_ngram_analyzer": {
          "type": "custom",
          "tokenizer": "single_char_ngram_tokenizer",
          "filter": [
            "lowercase"
          ]
        }
      }
    }
  },
  "mappings": {
    "properties": {
      "videoId": {
        "type": "keyword"
      },
      "title": {
        "type": "text",
        "analyzer": "ik_max_word",
        "fields": {
          "ngram": {
            "type": "text",
            "analyzer": "single_char_ngram_analyzer",
            "search_analyzer": "single_char_ngram_analyzer"
          },
          "keyword": {
            "type": "keyword"
          }
        }
      },
      "userId": {
        "type": "keyword"
      },
      "username": {
        "type": "text",
        "analyzer": "ik_max_word",
        "fields": {
          "ngram": {
            "type": "text",
            "analyzer": "single_char_ngram_analyzer",
            "search_analyzer": "single_char_ngram_analyzer"
          },
          "keyword": {
            "type": "keyword"
          }
        }
      },
      "coverUrl": {
        "type": "keyword"
      },
      "partitionId": {
        "type": "keyword"
      },
      "partitionName": {
        "type": "text",
        "analyzer": "ik_max_word",
        "fields": {
          "keyword": {
            "type": "keyword"
          }
        }
      },
      "tagList": {
        "type": "keyword"
      },
      "playCount": {
        "type": "long"
      },
      "createTime": {
        "type": "date",
        "format": "strict_date_hour_minute_second||strict_date_time||yyyy-MM-dd HH:mm:ss||epoch_millis"
      },
      "collectionCount": {
        "type": "long"
      },
      "duration": {
        "type": "integer"
      }
    }
  }
}
